{
  "color": {
    "base": {
      "paper":    { "value": "#FAFAFA", "role": "Основной фон страниц и карточек" },
      "ink":      { "value": "#1A1A1A", "role": "Заголовки, текст, иконки, линии" },
      "ink-soft": { "value": "#6B6B6B", "role": "Вторичный текст, мета, подписи" },
      "rule":     { "value": "#E0E0E0", "role": "Бордеры, разделители, пустые цифры" }
    },
    "pastel": {
      "malachite": {
        "value":    "#9DD4B9",
        "bg":       "#EDF7F2",
        "deep":     "#6FB596",
        "role":     "Заливка блока, большая сфера, чек-лист"
      },
      "lavender": {
        "value":    "#C5B4E8",
        "bg":       "#F3F0FB",
        "deep":     "#9F89C9",
        "role":     "Альтернативная заливка, парная карточка"
      },
      "sky": {
        "value":    "#A3C8E8",
        "bg":       "#EAF2F9",
        "deep":     "#7AA9CD",
        "role":     "Теги, плашка, фоновая сфера"
      }
    },
    "accent": {
      "signal": {
        "value": "#E63946",
        "role":  "Eyebrow-лейбл, кружок, точка. Никогда как заливка фона. Одна точка на страницу."
      }
    }
  },

  "typography": {
    "fontFamily": {
      "display": "Unbounded, sans-serif",
      "body":    "Inter, sans-serif",
      "mono":    "Courier Prime, monospace"
    },
    "weight": {
      "regular": 400,
      "medium":  500,
      "bold":    700
    },
    "size": {
      "h1":      "32pt",
      "h2":      "18pt",
      "h3":      "14pt",
      "lead":    "13pt",
      "body":    "10.5pt",
      "meta":    "8.5pt",
      "eyebrow": "8.5pt"
    },
    "lineHeight": {
      "tight":  1.1,
      "snug":   1.3,
      "normal": 1.55,
      "loose":  1.65
    },
    "tracking": {
      "tight": "-0.03em",
      "snug":  "-0.02em",
      "wide":  "0.04em"
    }
  },

  "spacing": {
    "scale-px": [8, 16, 24, 40, 64, 104],
    "scale-mm": ["2mm", "4mm", "6mm", "10mm", "16mm", "26mm"],
    "module":   "8px",
    "rule":     "Все отступы кратны 8px. Шкала — Фибоначчи."
  },

  "page": {
    "format": "A4",
    "width":  "210mm",
    "height": "297mm",
    "paddingX": "18mm",
    "paddingY": "14mm"
  },

  "radius": {
    "sharp": "2px",
    "soft":  "4px",
    "card":  "6px"
  },

  "rules": [
    "В одном кадре максимум 2 пастели + бумага + чернила",
    "Сигнальный красный — точечно, одна точка на страницу",
    "Текст только чернилами, не на пастельной подложке",
    "Большие пастельные формы могут выходить за край",
    "Сферы с текстом — плоские. Декоративные сферы — объёмные.",
    "Чередовать цвета сфер по страницам: малахит → лаванда → небо",
    "Чередовать размеры сфер: большая (≈80mm) → средняя (≈50mm)",
    "Текст занимает ~62% ширины. Остальные 38% — воздух или сфера.",
    "Только 2 веса Inter: 400 и 500",
    "Только sentence case. Никаких ЗАГЛАВНЫХ или TitleCase.",
    "Курсив — только цитаты"
  ]
}
